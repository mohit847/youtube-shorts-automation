# === YouTube Shorts Song Automation ===

# Gemini API Key (for song transcription + metadata)
GEMINI_API_KEY=your_gemini_api_key_here

# Cloudflare Workers AI Credentials (for free image generation)
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# Google Drive folder ID (the long string in the folder URL)
# Example: if folder URL is https://drive.google.com/drive/folders/1a2b3c4d5e6f
# then DRIVE_FOLDER_ID=1a2b3c4d5e6f
DRIVE_FOLDER_ID=your_drive_folder_id

# Processed folder ID (where songs go after successful upload)
DRIVE_PROCESSED_FOLDER_ID=your_processed_folder_id

# Path to OAuth2 client_secret.json from Google Cloud Console
YOUTUBE_CLIENT_SECRET_PATH=credentials/client_secret.json

# Upload settings
DEFAULT_PRIVACY=public
UPLOAD_CATEGORY_ID=10

# Video settings (seconds) — YouTube Shorts max is 60s
MAX_VIDEO_DURATION=59

# Song clip settings — skip intro seconds, then take MAX_VIDEO_DURATION
INTRO_SKIP_SECONDS=10

# Channel/Author name (used as default artist and in watermark)
WATERMARK_TEXT=Musiqstar
CHANNEL_NAME=Musiqstar

# Image generation settings (dynamic based on audio duration)
SECONDS_PER_IMAGE=3
MIN_IMAGES=4
MAX_IMAGES=15

# Call-to-action settings (shown at end of video)
CTA_TEXT=Like & Subscribe ❤️
CTA_DURATION=5
